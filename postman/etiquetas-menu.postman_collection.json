                "disabled": true
              }
            ],
            "url": {
              "raw": "{{url}}/admin/etiquetas-menu/{{etiqueta_menu_id}}/inactivar",
              "host": [
                "{{url}}"
              ],
              "path": [
                "admin",
                "etiquetas-menu",
                "{{etiqueta_menu_id}}",
                "inactivar"
              ]
            },
            "description": "PATCH /admin/etiquetas-menu/:id/inactivar. Devuelve 409 si ya esta inactiva."
          },
          "response": []
        },
        {
          "name": "Eliminar etiqueta de menu",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenant}}",
                "type": "text"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenant_key}}",
                "type": "text",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{url}}/admin/etiquetas-menu/{{etiqueta_menu_id}}",
              "host": [
                "{{url}}"
              ],
              "path": [
                "admin",
                "etiquetas-menu",
                "{{etiqueta_menu_id}}"
              ]
            },
            "description": "DELETE /admin/etiquetas-menu/:id. La etiqueta debe estar inactiva antes de eliminarse."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Public Etiquetas Menu",
      "description": "Endpoint publico registrado por EtiquetasMenuModule. No usa JWT, pero requiere tenant para aplicar el scope del servicio.",
      "item": [
