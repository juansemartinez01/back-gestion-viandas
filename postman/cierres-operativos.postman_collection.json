{
  "info": {
    "_postman_id": "b8f2ac22-7f8d-497a-a4ce-cierresoperativos01",
    "name": "Cierres Operativos - Rochester API",
    "description": "Coleccion para importar en Postman con los endpoints del modulo Cierres Operativos. Todos los endpoints requieren Bearer token y tenant.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
