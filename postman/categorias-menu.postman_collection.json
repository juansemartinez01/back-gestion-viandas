{
  "info": {
    "_postman_id": "4ff2d0a6-02f0-49c6-8769-cdb73f35618a",
    "name": "Backend Rochester - Categorias Menu",
    "description": "Coleccion para probar los endpoints del modulo Categorias de Menu. Usa {{url}}, {{token}}, {{tenant}} y {{categoria_menu_id}}.",
