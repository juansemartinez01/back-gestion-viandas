      "key": "url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenant",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenant_key",
      "value": "",
