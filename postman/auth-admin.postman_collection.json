  "item": [
    {
      "name": "Auth",
      "description": "Registro, login, refresh, logout y endpoints de sesion.",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant}}",
                "type": "text"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenant_key}}",
                "type": "text",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuevo.usuario@rochester.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{url}}/auth/register",
              "host": [
                "{{url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Crea un usuario en el tenant actual con rol user."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('token', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refresh_token', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant}}",
                "type": "text"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenant_key}}",
                "type": "text",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@rochester.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{url}}/auth/login",
              "host": [
                "{{url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Obtiene access_token y refresh_token. El test de Postman guarda ambos en variables de coleccion."
          },
          "response": []
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('token', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refresh_token', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{url}}/auth/refresh",
              "host": [
                "{{url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Rota refresh_token y devuelve un nuevo par de tokens."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{url}}/auth/logout",
              "host": [
                "{{url}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Revoca el refresh_token activo."
          },
          "response": []
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
